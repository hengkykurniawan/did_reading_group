. 
. // Going to use the same Wolfers and Stevenson (2006) example we have been
. 
. use http://pped.org/bacon_example.dta

. 
. // standard twfe to compare with
. gen K = year - _nfd
(429 missing values generated)

. 
. forvalues l = 0/14 {
  2.         gen L`l'_nfd = K == `l'
  3. }

. gen L15_nfd = K >= 20

. 
. forvalues l = 0/7 {
  2.         gen F`l'_nfd = K == `l'
  3. }

. gen F8_nfd = K <= -8

. 
. reghdfe asmrs o.F1_nfd o.F2_nfd F3_nfd-F8_nfd L*_nfd, a(stfips year) cluster(
> stfips)
reghdfe requires uses the require package to maintain its dependencies; please 
> install it:
 - install from SSC
 - install from GitHub
r(9);

