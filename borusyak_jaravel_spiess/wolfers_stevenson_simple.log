. estimates store did_imp

. 
. // event study plot
. event_plot did_imp did_base, stub_lag(tau# L#_nfd) stub_lead(pre# F#_nfd) tog
> ether ///
> plottype(scatter) default_look noautolegend ///
>                 graph_opt(xtitle("Days since the event") ytitle("OLS coeffici
> ents") xlabel(-8(1)15) legend(label (3 "OLS") label (1 "BJS")))
